# VectorDBZ V2 153 server profile.
# Copy to /etc/vectordbz/v2.env and fill secrets on the server.

VDBZ_APP_DIR=/opt/vectordbz-v2-harness
VDBZ_API_HOST=0.0.0.0
VDBZ_API_PORT=4636
VDBZ_CHECKPOINT_DIR=/var/lib/vectordbz_v2/checkpoints

CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

JINA_API_KEY=
DEEPINFRA_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=

LOG_LEVEL=INFO
